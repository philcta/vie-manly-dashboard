# ============================================
# Streamlit Cloud Secrets
# ============================================
# Copy these values into:
#   Streamlit Cloud → App Settings → Secrets
# OR into .streamlit/secrets.toml for local dev
#
# NEVER commit secrets.toml to Git!

[supabase]
url = "https://your-project.supabase.co"
key = "your-service-role-key"

[square]
access_token = "your-square-production-access-token"
application_id = "your-square-application-id"
location_id = "your-square-location-id"
environment = "production"
